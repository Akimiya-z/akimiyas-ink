---
import { Icon } from 'astro-pure/user'
import config, { socialProfiles } from '@/site-config'
import XiaohongshuIcon from '@/components/XiaohongshuIcon.astro'

const footerConf = config.footer
const footerLink1 = footerConf.links?.filter(({ pos }) => pos === 1) || []
const footerLink2 = footerConf.links?.filter(({ pos }) => pos === 2) || []

const socialEntries = [
  socialProfiles.github && { platform: 'github', label: 'GitHub', url: socialProfiles.github },
  socialProfiles.zhihu && { platform: 'zhihu', label: 'Zhihu', url: socialProfiles.zhihu },
  socialProfiles.bilibili && { platform: 'bilibili', label: 'Bilibili', url: socialProfiles.bilibili },
  socialProfiles.xiaohongshu && {
    platform: 'xiaohongshu',
    label: 'Xiaohongshu',
    url: socialProfiles.xiaohongshu
  },
  socialProfiles.email && { platform: 'email', label: 'Email', url: socialProfiles.email },
  { platform: 'rss', label: 'RSS', url: '/rss.xml' }
].filter(Boolean)
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='border-t pt-5'>
    <div class='flex items-center gap-y-3 max-sm:flex-col sm:justify-between sm:gap-y-0'>
      <div class='flex items-center gap-x-4 gap-y-2 text-muted-foreground max-sm:flex-col'>
        {
          footerLink1.length > 0 && (
            <div>
              {footerLink1.map(({ title, link, style }, index) => (
                <>
                  <a href={link} target='_blank' class={style}>{title}</a>
                  {index < footerLink1.length - 1 && <span class='mx-1'>•</span>}
                </>
              ))}
            </div>
          )
        }
        <div>
          {config.footer.year}
          {config.author}
          {
            footerLink2.length > 0 && (
              <>
                &
                <span>
                  {footerLink2.map(({ title, link, style }) => (
                    <span>
                      <a href={link} target='_blank' class={style}>{title}</a>
                    </span>
                  ))}
                </span>
              </>
            )
          }
        </div>
        {
          footerConf.credits && (
            <span>
              <a href='https://github.com/withastro/astro' target='_blank'>Astro</a>
              &
              <a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Pure</a>
              theme powered
            </span>
          )
        }
      </div>

      <div class='flex items-center gap-x-4'>
        {
          socialEntries.map(({ platform, label, url }) => (
            <a href={url} aria-label={label}>
              {
                platform === 'xiaohongshu' ? (
                  <XiaohongshuIcon class='size-7' />
                ) : (
                  <Icon name={platform as 'github' | 'zhihu' | 'bilibili' | 'email' | 'rss'} />
                )
              }
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  footer a {
    color: hsl(var(--foreground) / var(--un-text-opacity, 1));
    text-decoration: underline;
    font-weight: 500;
  }
</style>
